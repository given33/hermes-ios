{
  "expo": {
    "name": "Hermes Agent",
    "slug": "hermes-agent-ios",
    "scheme": "hermes-agent",
    "version": "2.0.0-beta.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.given33.hermesagent.nativebeta",
      "buildNumber": "9",
      "supportsTablet": true,
      "requireFullScreen": false,
      "infoPlist": {
        "CFBundleDisplayName": "Hermes Agent",
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleDevelopmentRegion": "zh_CN",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "用于在 Hermes 会话中拍照并上传。",
        "NSMicrophoneUsageDescription": "用于在 Hermes 会话中录制并上传音频。",
        "NSPhotoLibraryUsageDescription": "用于从照片图库选择图片并上传到 Hermes 会话。",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "允许 Hermes Agent 使用面容 ID 保护敏感凭据。"
        }
      ],
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "允许 Hermes Agent 使用面容 ID 验证身份。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "用于从照片图库选择图片并上传到 Hermes 会话。",
          "cameraPermission": "用于在 Hermes 会话中拍照并上传。",
          "microphonePermission": "用于在 Hermes 会话中录制并上传音频。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#170d02",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "hermesUrl": "https://8.138.40.16",
      "githubRepository": "given33/hermes-ios"
    }
  }
}
