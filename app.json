{
  "expo": {
    "name": "Hermes Agent",
    "slug": "hermes-agent-ios",
    "scheme": "hermes-agent",
    "version": "2.0.0-beta.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.given33.hermesagent.nativebeta",
      "buildNumber": "13",
      "supportsTablet": true,
      "requireFullScreen": false,
      "infoPlist": {
        "CFBundleDisplayName": "Hermes Agent",
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleDevelopmentRegion": "zh_CN",
        "CADisableMinimumFrameDurationOnPhone": true,
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "用于在 Hermes 会话中拍照并上传。",
        "NSMicrophoneUsageDescription": "用于在 Hermes 会话中录制并上传音频。",
        "NSPhotoLibraryUsageDescription": "用于从照片图库选择图片并上传到 Hermes 会话。",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.0"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Collapse-Bold.otf",
            "./assets/fonts/Collapse-Regular.otf",
            "./assets/fonts/Mondwest-Regular.ttf",
            "./assets/fonts/RulesCompressed-Medium.ttf",
            "./assets/fonts/RulesCompressed-Regular.ttf",
            "./assets/fonts/RulesExpanded-Bold.ttf",
            "./assets/fonts/RulesExpanded-Regular.ttf",
            "./assets/fonts/Google-Inter-400-Normal.ttf",
            "./assets/fonts/Google-Inter-500-Normal.ttf",
            "./assets/fonts/Google-Inter-600-Normal.ttf",
            "./assets/fonts/Google-Inter-700-Normal.ttf",
            "./assets/fonts/Google-IBMPlexSans-400-Normal.ttf",
            "./assets/fonts/Google-IBMPlexSans-500-Normal.ttf",
            "./assets/fonts/Google-IBMPlexSans-600-Normal.ttf",
            "./assets/fonts/Google-IBMPlexSans-700-Normal.ttf",
            "./assets/fonts/Google-WorkSans-400-Normal.ttf",
            "./assets/fonts/Google-WorkSans-500-Normal.ttf",
            "./assets/fonts/Google-WorkSans-600-Normal.ttf",
            "./assets/fonts/Google-WorkSans-700-Normal.ttf",
            "./assets/fonts/Google-AtkinsonHyperlegible-400-Normal.ttf",
            "./assets/fonts/Google-AtkinsonHyperlegible-700-Normal.ttf",
            "./assets/fonts/Google-DMSans-400-Normal.ttf",
            "./assets/fonts/Google-DMSans-500-Normal.ttf",
            "./assets/fonts/Google-DMSans-600-Normal.ttf",
            "./assets/fonts/Google-DMSans-700-Normal.ttf",
            "./assets/fonts/Google-Spectral-400-Normal.ttf",
            "./assets/fonts/Google-Spectral-500-Normal.ttf",
            "./assets/fonts/Google-Spectral-600-Normal.ttf",
            "./assets/fonts/Google-Spectral-700-Normal.ttf",
            "./assets/fonts/Google-Fraunces-400-Normal.ttf",
            "./assets/fonts/Google-Fraunces-500-Normal.ttf",
            "./assets/fonts/Google-Fraunces-600-Normal.ttf",
            "./assets/fonts/Google-SourceSerif4-400-Normal.ttf",
            "./assets/fonts/Google-SourceSerif4-500-Normal.ttf",
            "./assets/fonts/Google-SourceSerif4-600-Normal.ttf",
            "./assets/fonts/Google-SourceSerif4-700-Normal.ttf",
            "./assets/fonts/Google-JetBrainsMono-400-Normal.ttf",
            "./assets/fonts/Google-JetBrainsMono-500-Normal.ttf",
            "./assets/fonts/Google-JetBrainsMono-700-Normal.ttf",
            "./assets/fonts/Google-IBMPlexMono-400-Normal.ttf",
            "./assets/fonts/Google-IBMPlexMono-500-Normal.ttf",
            "./assets/fonts/Google-IBMPlexMono-700-Normal.ttf",
            "./assets/fonts/Google-SpaceMono-400-Normal.ttf",
            "./assets/fonts/Google-SpaceMono-700-Normal.ttf",
            "./assets/fonts/Google-ShareTechMono-400-Normal.ttf",
            "./assets/fonts/Google-DMMono-400-Normal.ttf",
            "./assets/fonts/Google-DMMono-500-Normal.ttf",
            "./assets/fonts/Terminal-JetBrainsMono-400-Normal.ttf",
            "./assets/fonts/Terminal-JetBrainsMono-400-Italic.ttf",
            "./assets/fonts/Terminal-JetBrainsMono-700-Normal.ttf"
          ]
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "允许 Hermes Agent 使用面容 ID 保护敏感凭据。"
        }
      ],
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "允许 Hermes Agent 使用面容 ID 验证身份。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "用于从照片图库选择图片并上传到 Hermes 会话。",
          "cameraPermission": "用于在 Hermes 会话中拍照并上传。",
          "microphonePermission": "用于在 Hermes 会话中录制并上传音频。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "extra": {
      "hermesUrl": "https://8.138.40.16",
      "githubRepository": "given33/hermes-ios"
    }
  }
}
