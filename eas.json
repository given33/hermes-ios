{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FRONTEND_PREVIEW": "0",
        "HERMES_DISTRIBUTABLE_BUILD": "1"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_FRONTEND_PREVIEW": "0",
        "HERMES_DISTRIBUTABLE_BUILD": "1"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_FRONTEND_PREVIEW": "0",
        "HERMES_DISTRIBUTABLE_BUILD": "1"
      }
    }
  }
}
